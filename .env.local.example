# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 速読管理システム認証情報（環境変数で管理、コードにハードコードしない）
SOKUDOKU_MANAGER_ID=
SOKUDOKU_MANAGER_PW=

# HMAC セッション署名用シークレット (32文字以上必須、ランダムな強固な値)
# 生成例: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
